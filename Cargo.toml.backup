[package]
name = "sovereign_core"
version = "6.2.0"
edition = "2021"
authors = ["Harmonis Prime Architect"]
description = "SovereignCore Rust substrate"

[lib]
name = "sovereign_core"
crate-type = ["cdylib", "rlib"]

[dependencies]
sha2 = "0.10"
pyo3 = { version = "0.21", features = ["extension-module"] }
serde = { version = "1.0", features = ["derive"] }
rand = "0.8"
serde_json = "1.0"
md5 = "0.7"
hex = "0.4"

[[bin]]
name = 'harmonis'
path = 'src/bin/harmonis.rs'
hex = "0.4"
